[Unit]
Description=AllStarLink Status OLED
After=network.target asterisk.service
Wants=asterisk.service
Conflicts=digi-gate.service

[Service]
ExecStart=/usr/bin/python3 /opt/allstarlink-status-oled/main.py
WorkingDirectory=/opt/allstarlink-status-oled
Restart=always
User=root

[Install]
WantedBy=multi-user.target